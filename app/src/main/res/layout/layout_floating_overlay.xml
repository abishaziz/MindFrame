<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Collapsed State: Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/app_icon"
        android:contentDescription="MindFrame"
        android:layout_gravity="center" />

    <!-- Expanded State: Chat Panel -->
    <LinearLayout
        android:id="@+id/panel_expanded"
        android:layout_width="320dp"
        android:layout_height="380dp"
        android:orientation="vertical"
        android:background="@drawable/overlay_bg"
        android:padding="20dp"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MindFrame"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <ImageButton
                android:id="@+id/btn_force_stop"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_stop_premium"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Force Stop"
                android:visibility="gone"
                android:layout_marginEnd="12dp" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_settings_gear"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:layout_marginEnd="12dp" />

            <ImageButton
                android:id="@+id/btn_minimize"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_close_premium"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Minimize" />
        </LinearLayout>

        <!-- Status Bar -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <!-- Chat Messages -->
        <ScrollView
            android:id="@+id/scroll_chat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/container_chat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </ScrollView>



        <!-- Save Skill Button (Visible after NEW task completes) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_skill"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Save Skill"
            android:textSize="11sp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent_approve"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <!-- Input Bar (The 'Footer') -->
        <LinearLayout
            android:id="@+id/layout_input"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_matte_pill"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp">

            <com.atwenty.mindframe.ui.view.BackAwareEditText
                android:id="@+id/et_input"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Ask me anything..."
                android:textColorHint="#AAAAAA"
                android:textColor="#F5F5F5"
                android:textSize="15sp"
                android:background="@null"
                android:singleLine="true"
                android:imeOptions="actionSend"
                android:importantForAutofill="no" />

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@android:drawable/ic_menu_send"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Send" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
