<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Collapsed State: Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_btn_speak_now"
        android:contentDescription="PersonalAgent"
        android:backgroundTint="#6200EE"
        android:layout_gravity="center" />

    <!-- Expanded State: Chat Panel -->
    <LinearLayout
        android:id="@+id/panel_expanded"
        android:layout_width="320dp"
        android:layout_height="380dp"
        android:orientation="vertical"
        android:background="@drawable/overlay_bg"
        android:padding="12dp"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PersonalAgent"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_force_stop"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_delete"
                android:tint="#D32F2F"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Force Stop"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_minimize"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Minimize" />
        </LinearLayout>

        <!-- Status Bar -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <!-- Chat Messages -->
        <ScrollView
            android:id="@+id/scroll_chat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/container_chat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </ScrollView>



        <!-- Feedback Buttons (Dev Mode, visible after task) -->
        <LinearLayout
            android:id="@+id/layout_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_feedback_success"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✅ Worked"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_feedback_fail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="❌ Failed"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Input Bar -->
        <LinearLayout
            android:id="@+id/layout_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <com.atwenty.personalagent.ui.view.BackAwareEditText
                android:id="@+id/et_input"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Ask me anything..."
                android:textColorHint="#808080"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:imeOptions="actionSend"
                android:importantForAutofill="no" />

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_send"
                android:background="@drawable/send_btn_bg"
                android:contentDescription="Send"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
