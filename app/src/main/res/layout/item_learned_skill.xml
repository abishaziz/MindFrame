<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_premium_card"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@android:drawable/ic_menu_agenda"
        android:contentDescription="Skill Icon"
        app:tint="@color/text_muted" />

    <TextView
        android:id="@+id/tv_skill_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Skill Name"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="12dp" />

    <ImageButton
        android:id="@+id/btn_delete_skill"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Delete Skill"
        app:tint="#D32F2F" />

</LinearLayout>
