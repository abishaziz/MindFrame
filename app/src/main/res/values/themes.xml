<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MindFrame" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_matte_grey</item>
        <item name="colorPrimary">@color/accent_cobalt</item>
    </style>

    <style name="Theme.MindFrame" parent="Base.Theme.MindFrame" />

    <style name="Theme.MindFrame.TextInput" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/bg_matte_grey</item>
        <item name="boxStrokeColor">@color/accent_cobalt</item>
        <item name="hintTextColor">@color/accent_cobalt</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
    </style>
</resources>
